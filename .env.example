# API service
# DATABASE_URL convention:
# - Local host runtime (README local setup): postgresql+asyncpg://postgres:postgres@localhost:5432/attend
# - Docker Compose runtime (this file):      postgresql+asyncpg://attend:attend@postgres:5432/attend
DATABASE_URL=postgresql+asyncpg://attend:attend@postgres:5432/attend
SERVER_ROLE=app
AI_WS_UPSTREAM_URL=ws://ai-backend:5679
SECRET_KEY=change-me-to-a-long-random-string
CORS_ORIGINS=https://app.example.com,https://www.app.example.com
API_PORT=5678

# Web service
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://api.example.com
